    "@sentry/node": "^8.45.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cico/config": "workspace:*",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
