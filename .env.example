# Postgres
POSTGRES_USER=cico
POSTGRES_PASSWORD=changeme
POSTGRES_DB=cico
POSTGRES_PORT=5432
PGDATA_PATH=./pgdata

# API
API_PORT=8787
NODE_ENV=development
DATABASE_URL=postgres://cico:changeme@localhost:5432/cico
SESSION_SECRET=replace-with-32-bytes-random
TZ=Europe/Zurich

# Frontend origin (Cloudflare Pages). Used as the post-OAuth redirect target
# and CORS allow-list (comma-separated).
WEB_BASE_URL=https://cico.lucanepa.com
ALLOWED_ORIGINS=https://cico.lucanepa.com

# Sentry
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development

# Oura
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8787/api/oauth/oura/callback

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8787/api/oauth/strava/callback
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Google Drive (Health Sync CSVs)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/oauth/google/callback
GOOGLE_DRIVE_FOLDER_ID=

# Cloudflare Tunnel (NAS deploy only)
TUNNEL_TOKEN=

# Foods
USDA_API_KEY=

# OCR (Claude Vision — claude-haiku-4-5)
ANTHROPIC_API_KEY=

# Cron
CRON_PREWARM_SCHEDULE=0 3 * * *
